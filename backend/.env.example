# Copie: copy .env.example .env
# Instâncias WhatsApp NÃO vão aqui — ficam no Supabase (criadas via /instance/create)

# --- Mistral ---
MISTRAL_API_KEY=

# --- Supabase ---
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Postgres direto (SQLTools — agente consulta o banco como interface)
# Supabase → Project Settings → Database → Connection string → URI (Session pooler)
# Use postgresql+psycopg://... (troque postgresql:// por postgresql+psycopg://)
SUPABASE_DB_URL=

# --- UAZAPI servidor (único para todas as academias) ---
UAZAPI_BASE_URL=https://onnzetecnologia.uazapi.com
UAZAPI_ADMIN_TOKEN=
UAZAPI_SEND_TEXT_PATH=/send/text

# --- Webhook global ---
WEBHOOK_SECRET=gere-um-token-longo
WEBHOOK_VALIDATE_QUERY=true

# URL pública após deploy Render (configurar webhook global)
PUBLIC_API_URL=

# --- API local ---
ENV=development
LOG_LEVEL=info
# debug = mais detalhes no terminal (Rich)

# Windows com erro CERTIFICATE_VERIFY_FAILED no AgentOS (proxy/antivírus):
# SSL_VERIFY=false
API_HOST=0.0.0.0
API_PORT=8000

# Academia: vem do Supabase (webhook → instância WhatsApp, ou tools listar/selecionar_academia)
QR_SIGNING_SECRET=change-me-in-production

AGENT_MODEL_DEFAULT=mistral-small-latest
AGENT_MODEL_SALES=mistral-large-latest
# AgentOS: use python run.py (porta 7780 fixa em run.py)
